{
  "name": "server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development tsx watch server.ts",
    "build": "node esbuild.config.cjs",
    "bundle": "node esbuild.config.cjs",
    "start": "node dist/server.cjs",
    "migrate": "npx sequelize-cli db:migrate --config config/config.cjs",
    "migrate:undo": "npx sequelize-cli db:migrate:undo --config config/config.cjs",
    "seed": "npx sequelize-cli db:seed:all --config config/config.cjs",
    "create-migration": "npx sequelize-cli migration:generate --name"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/openai": "^3.0.41",
    "@supabase/supabase-js": "^2.99.0",
    "ai": "^6.0.116",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "json5": "^2.2.3",
    "multer": "2.1.1",
    "nanoid": "^5.1.6",
    "path": "^0.12.7",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "pino": "^10.3.1",
    "sequelize": "^6.37.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.4.0",
    "esbuild": "^0.27.3",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
